{
  "manifest_version": 3,
  "name": "Tailchrome",
  "version": "0.1.0",
  "description": "Access your tailnet from your browser. Run a full Tailscale node per browser profile without affecting system networking.",
  "permissions": [
    "proxy",
    "storage",
    "nativeMessaging",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16-offline.png",
      "32": "icons/icon-32-offline.png",
      "48": "icons/icon-48-offline.png",
      "128": "icons/icon-128-offline.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
